[
    {
        "key": "ctrl+1",
        "command": "editor.action.blockComment",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "cmd+m",
        "command": "composerMode.chat",
        "when": "isMac"
    },
    {
        "key": "ctrl+m",
        "command": "composerMode.chat",
        "when": "isLinux || isWindows"
    },
    {
        "key": "shift+cmd+m",
        "command": "composerMode.agent",
        "when": "isMac"
    },
    {
        "key": "ctrl+shift+m",
        "command": "composerMode.agent",
        "when": "isLinux || isWindows"
    },
    {
        "key": "ctrl+shift+m",
        "command": "composerMode.plan",
        "when": "isMac"
    },
    {
        "key": "alt+shift+m",
        "command": "composerMode.plan",
        "when": "isLinux || isWindows"
    }
]